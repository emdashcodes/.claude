#!/bin/bash

# Claude Code Smart Wrapper
#
# This wrapper enhances Claude Code with the following features:
#
# 1. AUTO SYSTEM PROMPT INJECTION:
#    - Automatically loads PROMPT.md for interactive sessions (claude, claude -c, claude -r)
#    - Fast-path bypass for scripting commands (claude -p ...)
#    - Merges with existing --append-system-prompt if provided
#
# Usage:
#   claude                                        → Interactive mode with system prompt
#   claude -c                                     → Continue with system prompt
#   claude -r                                     → Resume with system prompt
#   claude -p "query"                             → Fast scripting mode (no system prompt)
#   CLAUDE_WRAPPER_DEBUG=1 claude                 → Enable debug output
#   CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=1 claude  → Add --dangerously-skip-permissions flag

REAL_CLAUDE="$HOME/.claude/local/node_modules/.bin/claude"

# If -p/--print flag is present, pass through immediately
for arg in "$@"; do
    if [[ "$arg" == "-p" || "$arg" == "--print" ]]; then
        exec "$REAL_CLAUDE" "$@"
    fi
done

# Simple settings - edit below or set via environment variables
DEBUG=${CLAUDE_WRAPPER_DEBUG:-0}
SKIP_PERMISSIONS=${CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS:-1}

debug() {
    if [[ $DEBUG -eq 1 ]]; then
        echo "[claude wrapper] $*" >&2
    fi
}

PROMPT_FILE="$HOME/.claude/PROMPT.md"

debug "Original args: $*"

if [[ ! -f "$PROMPT_FILE" ]]; then
    debug "Warning: System prompt file not found at $PROMPT_FILE" >&2
    exec "$REAL_CLAUDE" "$@"
    exit $?
fi

should_inject_prompt() {
    # Check if no arguments (interactive mode)
    if [[ $# -eq 0 ]]; then
        return 0
    fi

    # Check for -c/--continue or -r/--resume flags
    for arg in "$@"; do
        case "$arg" in
            -c|--continue|-r|--resume)
                return 0
                ;;
        esac
    done

    # Default: don't inject for other commands
    return 1
}

merge_system_prompt() {
    local args=()
    local has_system_prompt=false
    local existing_prompt=""

    local arg_array=("$@")
    local i=0

    while [[ $i -lt ${#arg_array[@]} ]]; do
        local arg="${arg_array[$i]}"
        case "$arg" in
            --append-system-prompt)
                has_system_prompt=true
                # Get the next argument (the existing prompt file/text)
                ((i++))
                if [[ $i -lt ${#arg_array[@]} ]]; then
                    existing_prompt="${arg_array[$i]}"
                fi
                ;;
            *)
                args+=("$arg")
                ;;
        esac
        ((i++))
    done

    local our_prompt_content
    our_prompt_content="$(cat "$PROMPT_FILE")"
    debug "System prompt loaded"

    if [[ $has_system_prompt == true ]]; then
        # Merge existing prompt with our prompt file
        local combined_prompt="$existing_prompt"$'\n\n'"$our_prompt_content"
        args+=(--append-system-prompt "$combined_prompt")
        debug "Merged with existing system prompt"
    else
        # No existing system prompt, just add ours
        args+=(--append-system-prompt "$our_prompt_content")
        debug "Added system prompt"
    fi

    # Add dangerous permissions flag if enabled
    if [[ $SKIP_PERMISSIONS -eq 1 ]]; then
        args+=(--dangerously-skip-permissions)
        debug "Added --dangerously-skip-permissions flag"
    fi

    exec "$REAL_CLAUDE" "${args[@]}"
}

# Main logic
if should_inject_prompt "$@"; then
    # Inject/merge the system prompt
    merge_system_prompt "$@"
else
    # Pass through, but add permissions flag if needed
    if [[ $SKIP_PERMISSIONS -eq 1 ]]; then
        debug "Added --dangerously-skip-permissions flag (passthrough)"
        exec "$REAL_CLAUDE" "$@" --dangerously-skip-permissions
    else
        exec "$REAL_CLAUDE" "$@"
    fi
fi
