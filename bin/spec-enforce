#!/bin/bash
# Spec Enforce - Re-enable workflow enforcement for current session

echo "🔒 Re-enabling spec workflow enforcement for this session..."

# Get session ID from environment
SESSION_ID="$CLAUDE_SESSION_ID"

if [ -z "$SESSION_ID" ]; then
    echo "   Error: No session ID available"
    echo "   Cannot remove session-specific lock"
    exit 1
fi

# Check for session-specific disable lock file
STATE_DIR=".claude/state"
DISABLE_FILE="$STATE_DIR/spec-disabled-$SESSION_ID"

if [ -f "$DISABLE_FILE" ]; then
    rm "$DISABLE_FILE"
    echo "   Removed enforcement disable lock for session: $SESSION_ID"
    echo ""
    echo "✅ Spec workflow enforcement re-enabled for this session"
    echo "   Future plan approvals will trigger automatic workflow enforcement"
    echo "   Any existing pending plan states will now be active"
else
    echo "   No disable lock found for session: $SESSION_ID"
    echo ""
    echo "ℹ️  Spec workflow enforcement is already active for this session"
fi

echo ""
echo "🎯 System returned to normal enforcement behavior"