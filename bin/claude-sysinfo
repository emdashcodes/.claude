#!/bin/bash
# Claude Code System Information Utility
# Provides common system information used by slash commands

case "$1" in
    "date")
        date +%Y-%m-%d
        ;;
    "time") 
        date +%H:%M
        ;;
    "pwd")
        pwd
        ;;
    "tmux-session")
        tmux display-message -p '#{session_name}' 2>/dev/null || echo "No tmux session"
        ;;
    "git-branch")
        git branch --show-current 2>/dev/null || echo "Not in git repository"
        ;;
    "git-status-count")
        git status --porcelain 2>/dev/null | wc -l | tr -d ' '
        ;;
    "git-worktree")
        git worktree list --porcelain 2>/dev/null | head -1 | sed 's/worktree //' || echo "No worktree"
        ;;
    "vault-config")
        cat ~/.claude/config/vault.json
        ;;
    "vault-entries-path")
        path=$(cat ~/.claude/config/vault.json | jq -r '.entries_path')
        echo "${path/#\~/$HOME}"
        ;;
    "vault-sessions-path") 
        path=$(cat ~/.claude/config/vault.json | jq -r '.sessions_path')
        echo "${path/#\~/$HOME}"
        ;;
    "vault-memory-path")
        path=$(cat ~/.claude/config/vault.json | jq -r '.memory_path')
        echo "${path/#\~/$HOME}"
        ;;
    "session-folder-path")
        sessions_path=$(cat ~/.claude/config/vault.json | jq -r '.sessions_path')
        expanded_path="${sessions_path/#\~/$HOME}"
        echo "$expanded_path/$(date +%Y/%m/%d)/"
        ;;
    "session-count-today")
        sessions_path=$(cat ~/.claude/config/vault.json | jq -r '.sessions_path')
        expanded_path="${sessions_path/#\~/$HOME}"
        ls -1 "$expanded_path/$(date +%Y/%m/%d)/" 2>/dev/null | wc -l | tr -d ' '
        ;;
    "all")
        echo "- Current date: $(claude-sysinfo date) (the date is in the format YYYY-MM-DD)"
        echo "- Current time: $(claude-sysinfo time)"
        echo "- Current working directory: $(claude-sysinfo pwd)"
        echo "- Current tmux session: $(claude-sysinfo tmux-session)"
        echo "- Current git branch: $(claude-sysinfo git-branch)"
        echo "- Current git status: $(claude-sysinfo git-status-count) files changed"
        echo "- Current git worktree: $(claude-sysinfo git-worktree)"
        ;;
    "session-context")
        echo "- Current date: $(claude-sysinfo date) (the date is in the format YYYY-MM-DD)"
        echo "- Current time: $(claude-sysinfo time)"
        echo "- Current working directory: $(claude-sysinfo pwd)"
        echo "- Current tmux session: $(claude-sysinfo tmux-session)"
        echo "- Vault configuration: $(claude-sysinfo vault-config)"
        echo "- Entries path: $(claude-sysinfo vault-entries-path)"
        echo "- Sessions path: $(claude-sysinfo vault-sessions-path)"
        echo "- Memory path: $(claude-sysinfo vault-memory-path)"
        echo "- Session folder path: $(claude-sysinfo session-folder-path)"
        echo "- Existing session count for today: $(claude-sysinfo session-count-today)"
        echo "- Current git branch: $(claude-sysinfo git-branch)"
        echo "- Current git status: $(claude-sysinfo git-status-count) files changed"
        echo "- Current git worktree: $(claude-sysinfo git-worktree)"
        ;;
    *)
        echo "Usage: claude-sysinfo <command>"
        echo ""
        echo "Commands:"
        echo "  date                - Current date (YYYY-MM-DD)"
        echo "  time                - Current time (HH:MM)"
        echo "  pwd                 - Current working directory"
        echo "  tmux-session        - Current tmux session name"
        echo "  git-branch          - Current git branch"
        echo "  git-status-count    - Number of changed files"
        echo "  git-worktree        - Current git worktree path"
        echo "  vault-config        - Full vault configuration"
        echo "  vault-entries-path  - Entries directory path"
        echo "  vault-sessions-path - Sessions directory path"
        echo "  vault-memory-path   - Memory directory path"
        echo "  session-folder-path - Today's session folder path"
        echo "  session-count-today - Count of today's sessions"
        echo "  all                 - All basic context info"
        echo "  session-context     - Context for session commands"
        ;;
esac